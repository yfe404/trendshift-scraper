{
    "title": "TrendShift.io Scraper Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "mode": {
            "title": "Scraping Mode",
            "type": "string",
            "description": "Which section of trendshift.io to scrape.",
            "editor": "select",
            "default": "dailyExplore",
            "enum": [
                "dailyExplore",
                "githubTrending",
                "trendingDevelopers",
                "repositoryEngagements",
                "stats"
            ],
            "enumTitles": [
                "Daily Explore (Top 25 by engagement)",
                "GitHub Trending Repositories",
                "Trending Developers",
                "Repository Engagements (monthly stars/forks/PRs)",
                "Language Stats (monthly stars/forks)"
            ]
        },
        "language": {
            "title": "Language Filter",
            "type": "string",
            "description": "Filter results by programming language (e.g. 'Python', 'TypeScript'). Applied post-extraction since server ignores this param for most modes.",
            "editor": "textfield"
        },
        "engagementMetric": {
            "title": "Engagement Metric",
            "type": "string",
            "description": "Which engagement metric to extract. Only used in repositoryEngagements mode.",
            "editor": "select",
            "default": "stars",
            "enum": [
                "stars",
                "forks",
                "mergedPrs",
                "issues",
                "closedIssues",
                "all"
            ],
            "enumTitles": [
                "Stars",
                "Forks",
                "Merged PRs",
                "Issues",
                "Closed Issues",
                "All Metrics"
            ]
        },
        "year": {
            "title": "Year",
            "type": "integer",
            "description": "Year for engagement/stats data (e.g. 2026). Used by repositoryEngagements mode.",
            "editor": "number"
        },
        "month": {
            "title": "Month",
            "type": "integer",
            "description": "Month for engagement/stats data (1-12). Used by repositoryEngagements mode.",
            "editor": "number",
            "minimum": 1,
            "maximum": 12
        },
        "maxPages": {
            "title": "Max Pages",
            "type": "integer",
            "description": "Maximum number of pages to scrape. Each page has ~25 results.",
            "default": 1,
            "minimum": 1,
            "maximum": 20
        },
        "proxyConfiguration": {
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Proxy configuration for anti-blocking.",
            "editor": "proxy",
            "sectionCaption": "Proxy and Browser configuration"
        }
    },
    "required": ["mode"]
}
